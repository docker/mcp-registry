[
  {
    "name": "analyze_url",
    "description": "Analyze a web page for screen-reader navigation cost",
    "inputSchema": {
      "type": "object",
      "properties": {
        "url": {"type": "string", "description": "URL to analyze"},
        "profile": {"type": "string", "description": "AT profile ID", "default": "generic-mobile-web-sr-v0"},
        "format": {"type": "string", "enum": ["json", "markdown", "console", "sarif"], "default": "sarif"},
        "explore": {"type": "boolean", "description": "Explore hidden branches", "default": false},
        "probe": {"type": "boolean", "description": "Run keyboard probes", "default": false},
        "waitForSelector": {"type": "string", "description": "CSS selector to wait for (SPAs)"},
        "summaryOnly": {"type": "boolean", "description": "Return only summary stats", "default": false}
      },
      "required": ["url"]
    }
  },
  {
    "name": "trace_path",
    "description": "Trace the screen-reader navigation path to a specific target",
    "inputSchema": {
      "type": "object",
      "properties": {
        "url": {"type": "string", "description": "URL of the page"},
        "target": {"type": "string", "description": "Target ID or glob pattern"},
        "profile": {"type": "string", "description": "AT profile ID", "default": "generic-mobile-web-sr-v0"}
      },
      "required": ["url", "target"]
    }
  },
  {
    "name": "list_profiles",
    "description": "List available assistive-technology profiles for scoring",
    "inputSchema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "diff_results",
    "description": "Compare two analysis results (before/after)",
    "inputSchema": {
      "type": "object",
      "properties": {
        "baseline": {"type": "string", "description": "Baseline analysis JSON"},
        "candidate": {"type": "string", "description": "Candidate analysis JSON"}
      },
      "required": ["baseline", "candidate"]
    }
  },
  {
    "name": "suggest_remediations",
    "description": "Extract top remediation suggestions ranked by severity",
    "inputSchema": {
      "type": "object",
      "properties": {
        "analysis": {"type": "string", "description": "Analysis result JSON"},
        "maxSuggestions": {"type": "number", "description": "Maximum suggestions to return", "default": 10}
      },
      "required": ["analysis"]
    }
  },
  {
    "name": "save_auth",
    "description": "Authenticate with a web app and save session state",
    "inputSchema": {
      "type": "object",
      "properties": {
        "url": {"type": "string", "description": "Login page URL"},
        "steps": {"type": "array", "description": "Login steps to execute"},
        "outputPath": {"type": "string", "description": "File path to save storageState", "default": "tactual-auth.json"}
      },
      "required": ["url", "steps"]
    }
  },
  {
    "name": "analyze_pages",
    "description": "Analyze multiple pages with site-level aggregation",
    "inputSchema": {
      "type": "object",
      "properties": {
        "urls": {"type": "array", "items": {"type": "string"}, "description": "URLs to analyze (2-20 pages)"},
        "profile": {"type": "string", "description": "AT profile ID", "default": "generic-mobile-web-sr-v0"}
      },
      "required": ["urls"]
    }
  }
]
